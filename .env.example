# GEMINI_API_KEY: Required for OpenRouter API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="sk-or-v1-..."

# GEMINI_MODEL: Default OpenRouter model to use if specific ones are not set
GEMINI_MODEL="google/gemini-3.1-pro-preview"

# Specific models for each agent (optional, defaults to GEMINI_MODEL)
EXTRACTOR_MODEL="google/gemini-3.1-pro-preview"
SEARCHER_MODEL="google/gemini-3-flash-preview"
VERIFIER_MODEL="google/gemini-3-flash-preview"
INSPECTOR_MODEL="google/gemini-3-flash-preview"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
